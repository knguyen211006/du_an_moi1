rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Hanzi collection: public read, authenticated write (for seed script)
    match /hanzi/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // User limits: read own doc only, STRICTLY NO client writes (backend only)
    match /userLimits/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false;
    }

    // Future collections can extend here
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

